VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
VITE_ENABLE_EMAIL_AUTOMATION=false

# Production frontend env on Vercel:
# VITE_SUPABASE_URL=https://haifftleyussrokyafqq.supabase.co
# VITE_SUPABASE_ANON_KEY=<public anon key>
# NEXT_PUBLIC_SUPABASE_URL=https://haifftleyussrokyafqq.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<public anon key>
# VITE_ENABLE_EMAIL_AUTOMATION=true

# Server/QA Supabase aliases. These are used by Node scripts and should not be
# exposed as browser secrets. SUPABASE_ANON_KEY is public, SERVICE_ROLE is not.
# SUPABASE_URL=https://haifftleyussrokyafqq.supabase.co
# SUPABASE_ANON_KEY=<public anon key>

# Supabase Edge Function secrets, not Vite/browser env:
# RESEND_API_KEY=
# MORROW_EMAIL_FROM=Morrow <auszeiten@getmorrow.de>
# MORROW_INTERNAL_LEAD_EMAIL=auszeiten@getmorrow.de
#
# Local package seed only:
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ACCESS_TOKEN=
#
# Public website QA:
# QA_BASE_URL=https://www.getmorrow.de
# MORROW_QA_SUBMIT_LEAD=0
# MORROW_QA_ALLOW_LAUNCH_BLOCKERS=0
#
# App production/staging QA:
# MORROW_QA_ALLOW_PARTIAL_APPS=0
# ADMIN_BASE_URL=https://<admin-app-domain>
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# OWNER_BASE_URL=https://<owner-app-domain>
# GUEST_BASE_URL=https://<guest-app-domain>
#
# Guest local QA / verification:
# GUEST_VERIFY_SEED=1
# GUEST_BOOKING_ID=11111111-1111-4111-8111-111111111111
# GUEST_ACCESS_CODE=MORROW1
# GUEST_VERIFY_SUPPORT_REPLY=0
#
# Owner local QA / verification:
# OWNER_VERIFY_TEMP_OWNER=1
# OWNER_VERIFY_SUPPORT_INSERT=1
# OWNER_VERIFY_DOCUMENT_ACCESS=1
# OWNER_VERIFY_STATEMENT_ACCESS=1
# OWNER_VERIFY_OPERATION_ACCESS=1
# OWNER_EMAIL=
# OWNER_PASSWORD=

# Launch gate confirmations, set only after the corresponding checks are truly done:
# MORROW_ADMIN_APP_URL=https://<admin-app-domain>
# MORROW_GUEST_APP_URL=https://<guest-app-domain>
# MORROW_OWNER_APP_URL=https://<owner-app-domain>
# MORROW_LEGAL_APPROVED_AT=2026-..-..
# MORROW_SECRETS_ROTATED_AT=2026-..-..
# MORROW_OFFER_DATA_APPROVED_AT=2026-..-..
# MORROW_TRACKING_APPROVED_AT=2026-..-..

# Optional tracking. Set only after consent/tracking decision is final.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# Backup/export scripts:
# MORROW_BACKUP_DIR=backups/supabase
# MORROW_BACKUP_PAGE_SIZE=1000

# Instagram organic publishing, server/automation only:
# Meta supports content publishing through the Instagram Platform for professional accounts.
# Assets must be fetchable by Meta during publishing. Prefer supabase-storage so
# creatives do not need to be published as website files.
INSTAGRAM_API_HOST=graph.instagram.com
INSTAGRAM_API_VERSION=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_PROFESSIONAL_ACCOUNT_ID=
INSTAGRAM_ASSET_PROVIDER=supabase-storage
INSTAGRAM_ASSET_BASE_URL=
INSTAGRAM_STORAGE_BUCKET=instagram-creatives
INSTAGRAM_SIGNED_URL_SECONDS=86400
INSTAGRAM_LAUNCH_DATE=
INSTAGRAM_INSIGHT_METRICS=reach,likes,comments,saved,shares,total_interactions
INSTAGRAM_PUBLISH_LOG=data/social/instagram-post-log.json
