{
  "name": "morrow-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run prototype:dev",
    "build": "npm run prototype:build",
    "prototype:dev": "vite",
    "prototype:build": "tsc -b && vite build",
    "web:dev": "npm run -w @morrow/web dev",
    "web:dev:port": "npm run web:dev -- --port 4300",
    "web:build": "npm run -w @morrow/web build",
    "web:start": "npm run -w @morrow/web start",
    "admin:dev": "npm run -w @morrow/admin dev",
    "admin:dev:port": "npm run admin:dev -- --port 4301",
    "admin:build": "npm run -w @morrow/admin build",
    "admin:start": "npm run -w @morrow/admin start",
    "owner:dev": "npm run -w @morrow/owner dev",
    "owner:dev:port": "npm run owner:dev -- --port 4320",
    "owner:build": "npm run -w @morrow/owner build",
    "owner:start": "npm run -w @morrow/owner start",
    "guest:dev": "npm run -w @morrow/guest dev",
    "guest:dev:port": "npm run guest:dev -- --port 4310",
    "guest:build": "npm run -w @morrow/guest build",
    "guest:start": "npm run -w @morrow/guest start",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:build": "bash scripts/build-database.sh",
    "supabase:backup": "node scripts/export-supabase-backup.mjs",
    "supabase:verify-admin": "node scripts/verify-supabase-admin-access.mjs",
    "supabase:verify-owner": "node scripts/verify-supabase-owner-portal.mjs",
    "supabase:verify-guest": "node scripts/verify-supabase-guest-stay.mjs",
    "events:scrape": "node scripts/scrape-spo-events.mjs",
    "supabase:seed-packages": "node scripts/seed-supabase-packages.mjs",
    "supabase:seed-local-places": "node scripts/seed-supabase-local-places.mjs",
    "supabase:seed-experiences": "node scripts/seed-supabase-experiences.mjs",
    "supabase:seed-owners-agencies": "node scripts/seed-supabase-owners-agencies.mjs",
    "supabase:seed-owner-access": "node scripts/seed-supabase-owner-access.mjs",
    "supabase:seed-customers-bookings": "node scripts/seed-supabase-customers-bookings.mjs",
    "supabase:seed-active-guest-test": "node scripts/seed-supabase-active-guest-test.mjs",
    "leads:discover": "node scripts/discover-leads.mjs",
    "instagram:dry-run": "node scripts/instagram-publisher.mjs dry-run next",
    "instagram:assets": "node scripts/instagram-publisher.mjs assets next",
    "instagram:post": "node scripts/instagram-publisher.mjs post due",
    "instagram:insights": "node scripts/instagram-publisher.mjs insights",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:production": "node scripts/qa-production-rehearsal.mjs",
    "qa:app-deployment-config": "node scripts/qa-app-deployment-config.mjs",
    "qa:apps": "node scripts/qa-apps-production.mjs",
    "qa:launch-gates": "node scripts/qa-launch-gates.mjs",
    "qa:prototype-storage": "node scripts/qa-prototype-storage-inventory.mjs",
    "qa:readiness": "node scripts/qa-readiness-summary.mjs",
    "qa:admin-parity:new": "node scripts/create-admin-parity-run.mjs",
    "qa:admin-parity:block1": "node scripts/qa-admin-parity-block1.mjs",
    "qa:admin-parity:preflight": "node scripts/qa-admin-parity-preflight.mjs",
    "qa:admin-parity:structure": "node scripts/qa-admin-parity-structure.mjs",
    "qa:admin-parity:status": "node scripts/report-admin-parity-status.mjs",
    "qa:admin-parity:validate": "node scripts/validate-admin-parity-run.mjs",
    "qa:admin-audit": "node scripts/qa-admin-audit-coverage.mjs",
    "qa:migration-consolidation": "node scripts/qa-migration-consolidation.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mingcute/react": "^1.4.1",
    "@supabase/supabase-js": "^2.107.0",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
